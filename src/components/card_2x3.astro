---
interface Props {
  info: {
    title: string;
    url: string;
    bgStyle?: string;
    textStyle?: string;
  };
}

const { info } = Astro.props;

// 处理动态背景图：提取 bg-[url('...')] 中的 URL 并转换为内联样式
let inlineStyle = "";
let bgClass = info.bgStyle || "";
const urlMatch = bgClass.match(/bg-\[url\(['"]?(.*?)['"]?\)\]/);
if (urlMatch) {
  inlineStyle = `background-image: url(${urlMatch[1]});`;
  // 移除该类名，避免潜在冲突
  bgClass = bgClass.replace(urlMatch[0], "").trim();
}
---

<a href={info.url} target="_blank">
  <div
    class:list={[
      "card max-lg:card-compact rounded-2xl shadow-xl w-full aspect-[9/16] lg:w-[12rem] lg:h-[21.33rem] mb-8",
      bgClass,
    ]}
    style={inlineStyle}
  >
    <div class="card-body rounded-2xl w-full h-full !p-0 relative">
      <div class="h-full w-full"></div>
      <div class="absolute bottom-0 w-full p-4 glass rounded-b-2xl">
        <p class:list={[info.textStyle, "card-title text-base"]}>
          {info.title}
        </p>
      </div>
    </div>
  </div>
</a>
