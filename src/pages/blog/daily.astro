---
import StickyNav from "../../components/sticky_nav.astro";
---

<!doctype html>
<html lang="zh-CN" data-theme="black">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daily Fragment | Devin's Nest</title>
    <meta name="description" content="Daily life fragments and photography" />
    <link
      rel="preload"
      href="/fonts/MaoKenZhuYuanTi.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <style>
      @font-face {
        font-family: "MaokenZhuyuanTi";
        src: url(/fonts/MaoKenZhuYuanTi.ttf);
        font-display: swap;
      }
      body {
        font-family: "MaokenZhuyuanTi", sans-serif;
        background-color: #0f0f11;
        color: #e5e7eb;
      }
      
      .hero-image {
        animation: scale-in 10s ease-out forwards;
      }
      @keyframes scale-in {
        0% { transform: scale(1.1); }
        100% { transform: scale(1.0); }
      }

      .hide-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body class="antialiased min-h-screen">
    <StickyNav showImmediately={true} />

    <!-- 客户端渲染容器 -->
    <div id="article-container" class="opacity-0 transition-opacity duration-500">
        <!-- Loading State -->
        <div class="min-h-screen flex items-center justify-center">
            <span class="loading loading-dots loading-lg text-emerald-500"></span>
        </div>
    </div>

    <script>
      import { snippetApi } from "../../api/snippet";
      import type { SnippetListItem, ContentBlock } from "../../api/snippet";

      function renderArticle(data: SnippetListItem) {
        // 解析 content
        let contentBlocks: ContentBlock[] = [];
        if (Array.isArray(data.content)) {
            contentBlocks = data.content;
        } else if (typeof data.content === 'string') {
            try {
                const parsed = JSON.parse(data.content);
                if (Array.isArray(parsed)) {
                    contentBlocks = parsed;
                } else {
                    contentBlocks = [{ type: 'text', content: data.content }];
                }
            } catch (e) {
                contentBlocks = [{ type: 'text', content: data.content }];
            }
        }

        // 提取 Hero Image (优先使用 root cover, 其次 root images, 其次查找内容中的图片)
        let heroImage = '';
        if (data.cover) {
            heroImage = data.cover;
        } else if (data.images && data.images.length > 0) {
            heroImage = data.images[0];
        } else {
            const imgBlock = contentBlocks.find(b => b.type === 'image' || (b.type === 'gallery' && b.images && b.images.length > 0));
            if (imgBlock) {
                if (imgBlock.type === 'image' && imgBlock.src) heroImage = imgBlock.src;
                else if (imgBlock.type === 'gallery' && imgBlock.images) heroImage = imgBlock.images[0];
            }
        }

        // 提取标题
        let displayTitle = 'Untitled Fragment';
        if (data.title) {
            displayTitle = data.title;
        } else {
            const titleBlock = contentBlocks.find(b => (b.type === 'text' || b.type === 'quote') && b.content);
            if (titleBlock && titleBlock.content) {
                displayTitle = titleBlock.content.split('\n')[0];
            } else if (data.createdAt || data.createTime) {
                displayTitle = data.createdAt || data.createTime || '';
            }
        }
        
        // 日期处理 (优先使用 createdAt, 兼容 createTime)
        let displayDate = data.createdAt || data.createTime || '';
        // 简单格式化日期 (如果是 ISO 字符串)
        if (displayDate.includes('T')) {
            const date = new Date(displayDate);
            if (!isNaN(date.getTime())) {
                displayDate = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
            }
        }
        
        document.title = `${displayTitle.substring(0, 20)}... | Devin's Nest`;
        
        // 渲染 Hero Section
        const heroHtml = `
            <header class="relative h-[60vh] md:h-[85vh] w-full overflow-hidden">
              <div class="absolute inset-0 bg-black/30 z-10"></div>
              <div class="absolute inset-0 bg-gradient-to-t from-[#0f0f11] via-transparent to-transparent z-20"></div>
              ${heroImage ? `<img src="${heroImage}" alt="Cover" class="absolute inset-0 w-full h-full object-cover hero-image" />` : ''}
              <div class="absolute bottom-0 left-0 w-full z-30 px-6 pb-20 md:pb-24 max-w-5xl mx-auto md:px-12">
                <div class="flex flex-col gap-4 animate-fade-up">
                  <div class="flex items-center gap-3 text-emerald-400 font-mono text-sm tracking-wider uppercase">
                    ${displayDate ? `
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                      ${displayDate}
                    </span>
                    ` : ''}
                    
                    <span class="w-1 h-1 bg-emerald-400 rounded-full"></span>
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                      ${data.location || '未知地点'}
                    </span>

                    ${data.views ? `
                    <span class="w-1 h-1 bg-emerald-400 rounded-full"></span>
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                      ${data.views}
                    </span>
                    ` : ''}
                  </div>
                  <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white leading-tight drop-shadow-lg line-clamp-2">
                    ${displayTitle}
                  </h1>
                  ${data.subtitle ? `<p class="text-lg md:text-xl text-gray-300 drop-shadow-md mt-2">${data.subtitle}</p>` : ''}
                  <div class="mt-6 flex flex-wrap gap-4 text-sm text-gray-400 border-t border-white/10 pt-6 max-w-xl">
                    <div class="flex items-center gap-2">
                      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
                      ${data.weather || '未知天气'}
                    </div>
                    <div class="flex items-center gap-2">
                      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                      <span class="text-lg">${data.mood || '未知心情'}</span>
                    </div>
                    ${data.tags ? data.tags.map(tag => `<span class="px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs">${tag}</span>`).join('') : ''}
                  </div>
                </div>
              </div>
            </header>
        `;

        // 渲染正文 Blocks
        const blocksHtml = contentBlocks.map(block => {
            switch(block.type) {
                case 'image':
                    return `
                        <div class="my-12 group">
                            <div class="relative overflow-hidden rounded-2xl shadow-2xl">
                                <img src="${block.src}" alt="${block.caption || ''}" loading="lazy" class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.02]" />
                            </div>
                            ${block.caption ? `<p class="mt-3 text-center text-sm text-gray-500 italic">${block.caption}</p>` : ''}
                        </div>
                    `;
                case 'gallery':
                    if (!block.images || block.images.length === 0) return '';
                    return `
                        <div class="my-16">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                                ${block.images.map(img => `
                                    <div class="relative group overflow-hidden rounded-xl shadow-lg aspect-[4/3]">
                                        <img src="${img}" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                                    </div>
                                `).join('')}
                            </div>
                            ${block.caption ? `<p class="mt-4 text-center text-sm text-gray-500 italic">${block.caption}</p>` : ''}
                        </div>
                    `;
                case 'quote':
                    return `
                        <blockquote class="my-16 pl-6 border-l-4 border-emerald-500/50 italic text-xl md:text-2xl text-gray-300 leading-relaxed relative">
                            <span class="absolute -left-3 -top-2 text-6xl text-emerald-500/20 font-serif">“</span>
                            <p>${block.content}</p>
                            ${block.author ? `<footer class="mt-4 text-sm text-gray-500 not-italic">— ${block.author}</footer>` : ''}
                        </blockquote>
                    `;
                case 'text':
                default:
                    if (!block.content) return '';
                    return `
                        <div class="prose-text text-gray-300 text-lg md:text-xl my-8 leading-relaxed tracking-wide whitespace-pre-wrap">
                            ${block.content}
                        </div>
                    `;
            }
        }).join('');

        const contentHtml = `
            <main class="relative z-20 pb-20">
                <div class="article-content max-w-4xl mx-auto px-5 md:px-8 pt-12">
                     ${blocksHtml}
                     
                     ${/* 如果 contentBlocks 中没有包含图片，且 root images 存在，则在底部显示（兼容旧数据） */
                       (contentBlocks.every(b => b.type === 'text') && data.images && data.images.length > 0) ? `
                        <div class="my-16 md:my-24">
                            <div class="grid grid-cols-1 ${data.images.length > 1 ? 'md:grid-cols-2' : ''} gap-4 md:gap-8">
                                ${data.images.map(img => `
                                    <div class="relative group overflow-hidden rounded-2xl shadow-lg">
                                        <img src="${img}" loading="lazy" class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105" />
                                    </div>
                                `).join('')}
                            </div>
                        </div>
                     ` : ''}
                </div>

                <div class="max-w-4xl mx-auto px-5 md:px-8">
                    <div class="mt-32 mb-20 pt-10 border-t border-white/10 text-center">
                    <div class="inline-flex items-center gap-2 text-emerald-400 mb-4">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        <span class="text-xl font-bold">Thanks for reading</span>
                    </div>
                    <p class="text-gray-500 text-sm">
                        本篇内容发布于 ${displayDate}
                    </p>
                    <div class="mt-8">
                        <a href="/fragmentlist" class="btn btn-outline border-white/20 text-gray-300 hover:bg-white/10 hover:border-emerald-500 hover:text-emerald-400 rounded-full px-8">
                        返回列表
                        </a>
                    </div>
                    </div>
                </div>
            </main>
        `;

        const container = document.getElementById('article-container');
        if (container) {
            container.innerHTML = heroHtml + contentHtml;
            container.classList.remove('opacity-0');
            container.classList.add('opacity-100');
        }
      }

      function renderError(message: string) {
        const container = document.getElementById('article-container');
        if (container) {
            container.innerHTML = `
                <div class="min-h-screen flex items-center justify-center text-gray-500">
                    <div class="text-center">
                        <h1 class="text-4xl font-bold mb-4">404</h1>
                        <p class="mb-8">${message}</p>
                        <a href="/fragmentlist" class="btn btn-primary">返回列表</a>
                    </div>
                </div>
            `;
            container.classList.remove('opacity-0');
            container.classList.add('opacity-100');
        }
      }

      // 初始化逻辑
      document.addEventListener('DOMContentLoaded', async () => {
        const urlParams = new URLSearchParams(window.location.search);
        const id = urlParams.get('id');
        
        if (!id) {
            window.location.href = '/fragmentlist';
            return;
        }

        // 显示初始 Loading 状态（虽然 HTML 里已经有了，但确保透明度正确）
        const container = document.getElementById('article-container');
        if (container) container.classList.remove('opacity-0');

        try {
            const data = await snippetApi.getSnippetDetail(id);
            console.log('data', data);
            if (data) {
                renderArticle(data);
            } else {
                renderError('未找到该碎片');
            }
        } catch (e) {
            console.error('Failed to load snippet data', e);
            renderError('加载失败，请稍后重试');
        }
      });
    </script>
  </body>
</html>